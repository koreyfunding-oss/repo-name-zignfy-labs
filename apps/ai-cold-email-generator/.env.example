# Ollama
# URL for the local Ollama instance (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use (default: llama3)
OLLAMA_MODEL=llama3

# Square hosted checkout URL
# After creating a payment link in the Square Dashboard, paste the URL here.
# The URL must redirect back to /unlock?success=true after payment.
NEXT_PUBLIC_SQUARE_CHECKOUT_URL=https://checkout.square.site/YOUR_PAYMENT_LINK_HERE
