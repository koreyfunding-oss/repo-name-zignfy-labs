# Ollama (local development)
# URL for the local Ollama instance (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use (default: llama3)
OLLAMA_MODEL=llama3

# OpenAI (cloud / Vercel deployment)
# When OPENAI_API_KEY is set the app uses the OpenAI API instead of Ollama.
# This is required for deployment on Vercel or any hosted environment where
# a local Ollama instance is not available.
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: override the OpenAI-compatible base URL (e.g. for Azure OpenAI or
# other OpenAI-compatible providers). Defaults to https://api.openai.com
# OPENAI_BASE_URL=https://api.openai.com

# Square hosted checkout URL
# After creating a payment link in the Square Dashboard, paste the URL here.
# The URL must redirect back to /unlock?success=true after payment.
NEXT_PUBLIC_SQUARE_CHECKOUT_URL=https://checkout.square.site/YOUR_PAYMENT_LINK_HERE
